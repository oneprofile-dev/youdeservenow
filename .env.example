# Gemini API — get free key at ai.google.dev (no credit card required)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API — get free key at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Amazon Associates tracking tag
AMAZON_AFFILIATE_TAG=youdeservenow-20

# Vercel KV — auto-injected when you create KV database in Vercel dashboard
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://youdeservenow.com

# Optional: Google AdSense publisher ID
NEXT_PUBLIC_ADSENSE_ID=

# Optional: set to "true" to enable verbose AI logging
AI_DEBUG=
