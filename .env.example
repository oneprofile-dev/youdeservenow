# Gemini API — get free key at ai.google.dev (no credit card required)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API — get free key at console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Amazon Associates tracking tag
AMAZON_AFFILIATE_TAG=youdeserven07-20

# Vercel KV — auto-injected when you create KV database in Vercel dashboard
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Vercel Blob — auto-injected when you create Blob store in Vercel dashboard
# Used to persist per-result OG images so social crawlers never see a cold start
BLOB_READ_WRITE_TOKEN=

# AI Circuit Breaker — stop calling AI at 80% of this daily limit (default: 100)
# Increase if you upgrade to paid Groq/Gemini tiers
CIRCUIT_BREAKER_DAILY_LIMIT=100

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://youdeservenow.com

# Optional: Google AdSense publisher ID
NEXT_PUBLIC_ADSENSE_ID=

# Optional: set to "true" to enable verbose AI logging
AI_DEBUG=

# Resend — email capture (get free API key at resend.com)
# Create an Audience in Resend dashboard, copy the Audience ID
RESEND_API_KEY=
RESEND_AUDIENCE_ID=
